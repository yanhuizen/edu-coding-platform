{
  "name": "edu-coding-platform-backend",
  "version": "0.1.0",
  "description": "K12 Python coding platform backend (Express + MongoDB)",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed:courses": "tsx scripts/seed-courses.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
